        "Double overhead cam (DOHC)",
        "Overhead valves (OHV)",
        "Single overhead cam (SOHC)"
      ]
    },
    "drive_type": {
      "maxLength": 32,
      "type": "string",
      "description": "The drive type which delivers power to the wheels.",
      "enum": [
        "all wheel drive",
        "four wheel drive",
        "front wheel drive",
        "rear wheel drive"
      ]
